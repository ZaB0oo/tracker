# Copy this file to `.env` and fill in your values.
# Create an OAuth application at https://osu.ppy.sh/home/account/edit
# (OAuth section) and set the callback URL to http://localhost:3727/api/auth/callback
OSU_CLIENT_ID=
OSU_CLIENT_SECRET=
OSU_USER_ID=

PORT=3727
DB_PATH=./data/tracker.db
# Max API requests per minute (or else peppy angry)
API_RPM=60
# Default score-polling interval (seconds). Optional: can be changed live in the
# app's settings menu, which overrides this value.
POLL_INTERVAL_SECONDS=120

# Optional: absolute path to LazerCollectionImporter.exe to enable direct
# import of collections into osu!lazer from the Maps tab.
# LAZER_IMPORTER_PATH=C:\path\to\LazerCollectionImporter.exe
